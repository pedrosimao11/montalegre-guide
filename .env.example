# ============================================================
# MONTALEGRE GUIDE — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ------------------------------------------------------------
# Google Maps / Places API
# ------------------------------------------------------------
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select existing)
# 3. Enable these APIs:
#    - Maps JavaScript API
#    - Places API
#    - Directions API (optional, for directions links)
# 4. Create an API Key under Credentials
# 5. Restrict the key:
#    - HTTP referrers: your domain (localhost:3000/* for dev)
#    - API restrictions: Maps JavaScript API + Places API
#
# Server-side key (used in Next.js API routes — never sent to browser)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Client-side key (only used to load the Maps JS SDK in the browser)
# You can use the same key or a separate browser-restricted one
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
